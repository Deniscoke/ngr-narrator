# ============================================================
# Dračí Hlídka — šablona proměnných prostředí
# Zkopíruj do .env.local a doplň hodnoty
# ============================================================

# --- OpenAI (POVINNÉ pro AI mód) ---
# Získáš na: https://platform.openai.com/api-keys
NARRATOR_AI_API_KEY=sk-...

# --- OpenAI model (volitelné, výchozí: gpt-4o-mini) ---
# NARRATOR_AI_MODEL=gpt-4o-mini

# --- Supabase (volitelné) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
